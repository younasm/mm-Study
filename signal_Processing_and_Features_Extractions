% ---- acquisition / chirp parameters (shared by every file) ----
P.numADCSamples = 256;
P.numTx         = 2;                              % TDM-MIMO: 2 Tx
P.numRx         = 4;
P.loops         = 128;                            % total chirps per frame (both Tx)
P.frames        = 200;
P.c             = 3e8;
P.f_c           = 77e9;
P.lambda        = P.c / P.f_c;
P.B             = 3997.56e6;
P.rangeRes      = P.c / (2 * P.B);
P.chirpDuration = 50e-3;                          % per-frame Doppler interval (PRT)
P.numVirtualRx     = P.numRx * P.numTx;          % 8 virtual channels
P.numChirpsVirtual = P.loops / P.numTx;          % 64 chirps after de-interleave
P.rangeStart    = 1;                             % range bins to integrate over Doppler-time
P.rangeEnd      = 100;
P.minArea       = 3;
P.floor_dB      = -25;        % floor for the grayscale ROI save
P.floor_dB_rgb  = -30;        % floor for the RGB spectrogram save
