stdSpec   = std(dopplerTimeMap_dB(:));
threshold = meanSpec + 2 * stdSpec;
binaryMask = dopplerTimeMap_dB > threshold;
CC    = bwconncomp(binaryMask);
stats = regionprops(CC, 'Area');
minArea = 3;
filteredMask = false(size(binaryMask));
for i = 1:numel(stats)
    if stats(i).Area > minArea
        filteredMask(CC.PixelIdxList{i}) = true;
    end
end
maskedSpectrogram = dopplerTimeMap_dB .* filteredMask;
% ---- Plot 2: masked ROI (gray) ----
