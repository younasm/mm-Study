imagesc(timeAxis, velocityAxis, maskedSpectrogram);
colorbar; colormap(gray);
set(gca, 'YDir', 'normal');
xlabel('Time (s)'); ylabel('Velocity (m/s)');
title('Masked Velocity-Time Spectrogram with ROI');


%% ===================== ROI map + two feature sets =====================
% From above: avgDopplerMagnitude (peak-normalized linear, [vel x time]),
%             velocityAxis [1 x loops], timeAxis [1 x frames]

avgDopplerMagnitude_dB = 20*log10(avgDopplerMagnitude + eps);
saveTag  = 'object2';
floor_dB = -25;          % display/save floor (matches your ~-22 dB colorbar)

% ---------- 1. ROI mask (your original adaptive method -> Image 1) ----------
meanSpec  = mean(avgDopplerMagnitude_dB(:));
stdSpec   = std(avgDopplerMagnitude_dB(:));
threshold = meanSpec + 2*stdSpec;

binaryMask = avgDopplerMagnitude_dB > threshold;
CC    = bwconncomp(binaryMask);
stats = regionprops(CC, 'Area');
minArea = 3;
filteredMask = false(size(binaryMask));
for i = 1:numel(stats)
    if stats(i).Area > minArea
        filteredMask(CC.PixelIdxList{i}) = true;
    end
end
maskedSpectrogram = avgDopplerMagnitude_dB .* filteredMask;   % gray ROI map

% ---------- 2. ROI morphology features (from the gray ROI mask) ----------
% Treat the whole foreground as ONE region (union of all blobs) so each
% descriptor is a single value per sample. Label matrix = all foreground -> 1.
Lall = double(filteredMask);
roiStats = regionprops(Lall, 'Area','Centroid','Orientation','Perimeter', ...
                             'MajorAxisLength','MinorAxisLength','Eccentricity');

roiFeat.Area            = roiStats.Area;             % pixels
roiFeat.Centroid        = roiStats.Centroid;         % [x=time-idx, y=vel-idx]
roiFeat.Orientation     = roiStats.Orientation;      % degrees
roiFeat.Perimeter       = roiStats.Perimeter;        % pixels
roiFeat.MajorAxisLength = roiStats.MajorAxisLength;  % pixels
roiFeat.MinorAxisLength = roiStats.MinorAxisLength;  % pixels
roiFeat.Eccentricity    = roiStats.Eccentricity;     % 0=circle, 1=line

% ---------- 3. Spectrogram features (from the FULL doppler-time spectrum) --
P = avgDopplerMagnitude;          % full linear power, [vel x time]
v = velocityAxis(:);              % [vel x 1]

% Energy curve (per time frame, over all velocity bins)
energyCurve = sum(P, 1);                                    % [1 x frames]

% Doppler centroid + bandwidth curves (power-weighted, per time frame)
W = P ./ (sum(P,1) + eps);
centroidCurve  = sum(W .* v, 1);                            % [1 x frames]
bandwidthCurve = sqrt(sum(W .* (v - centroidCurve).^2, 1)); % [1 x frames]

% Entropy (Shannon, over whole spectrogram power distribution)
p = P(:); p = p / (sum(p) + eps);
specEntropy = -sum(p .* log2(p + eps));

% Skewness of the power-weighted velocity marginal (micro-Doppler asymmetry)
Pv = sum(P,2); wv = Pv / (sum(Pv) + eps);
muV  = sum(wv .* v);
sigV = sqrt(sum(wv .* (v - muV).^2));
specSkewness = sum(wv .* (v - muV).^3) / (sigV^3 + eps);

specFeat.entropy        = specEntropy;
specFeat.skewness       = specSkewness;
specFeat.centroidCurve  = centroidCurve;    % sequence input
specFeat.bandwidthCurve = bandwidthCurve;   % sequence input
specFeat.energyCurve    = energyCurve;      % sequence input
specFeat.centroidMean   = mean(centroidCurve);
specFeat.bandwidthMean  = mean(bandwidthCurve);
specFeat.energyTotal    = sum(energyCurve);

% ---------- 4. Borderless save of the gray ROI map (dataset image) ----------
gimg = (maskedSpectrogram - floor_dB) / (0 - floor_dB);   % 0 dB bg -> white
gimg = flipud(min(max(gimg,0),1));                        % match normal-Y display
imwrite(im2uint8(gimg), sprintf('ROI_%s_gray.png', saveTag));

% ---------- 5. Save features ----------
save(sprintf('FEAT_%s.mat', saveTag), 'roiFeat', 'specFeat');

featRow = table(string(saveTag), ...
    roiFeat.Area, roiFeat.Orientation, roiFeat.Centroid(1), roiFeat.Centroid(2), ...
    roiFeat.Perimeter, roiFeat.MajorAxisLength, roiFeat.MinorAxisLength, roiFeat.Eccentricity, ...
    specFeat.entropy, specFeat.skewness, specFeat.centroidMean, specFeat.bandwidthMean, specFeat.energyTotal, ...
    'VariableNames', {'FileName','Area','Orientation','CentroidX','CentroidY', ...
    'Perimeter','MajorAxis','MinorAxis','Eccentricity', ...
    'Entropy','Skewness','CentroidMean','BandwidthMean','EnergyTotal'});

% ---------- 6. Verification: the two correct plots ----------
figure;
imagesc(timeAxis, velocityAxis, max(avgDopplerMagnitude_dB, floor_dB));
set(gca,'YDir','normal'); colormap(jet); colorbar;
xlabel('Time (s)'); ylabel('Velocity (m/s)'); title('Doppler-Time Spectrogram (dB)');

figure;
imagesc(timeAxis, velocityAxis, maskedSpectrogram);
set(gca,'YDir','normal'); colormap(gray); colorbar;
xlabel('Time (s)'); ylabel('Velocity (m/s)'); title('Extracted ROI (gray)');


