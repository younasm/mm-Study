% with TDM-MIMO

clear all; clc;
% Load Data
filename = '/Users/younas/Dev/Matlab/mmStudy/expended dataset/100d/drink/d1_Raw_0.bin';
adcDataRaw = readDCA1000(filename);
% Parameters
numADCSamples  = 256;
numTx          = 2;
numRx          = 4;
loops          = 128;
frames         = 100;
c               = 3e8;
f_c             = 77e9;
lambda          = c / f_c;
d               = lambda / 2;
B               = 3997.56e6;
chirpDuration   = 50e-3;
rangeResolution = c / (2 * B);
numVirtualRx     = numRx * numTx;
numChirpsVirtual = loops / numTx;
% Reshape [Rx, ADCSamples, Chirps, Frames]
adcDataRaw = reshape(adcDataRaw, numRx, numADCSamples, loops, frames);
% Virtual Array Formation (TDM-MIMO)
adcDataVirtual = zeros(numVirtualRx, numADCSamples, numChirpsVirtual, frames);
for txIdx = 1:numTx
    adcDataVirtual((txIdx-1)*numRx+1:txIdx*numRx, :, :, :) = ...
        adcDataRaw(:, :, txIdx:numTx:end, :);
end
% Range FFT
window1D       = hamming(numADCSamples)';
adcDataVirtual = adcDataVirtual .* window1D;
adcDataVirtual = adcDataVirtual - mean(adcDataVirtual, 3);  % within-frame clutter removal
rangeFFT = fft(adcDataVirtual, numADCSamples, 2);
rangeFFT = rangeFFT / numADCSamples;
rangeFFT = rangeFFT(:, 1:numADCSamples/2, :, :);
% Cross-frame clutter removal (ENABLED) -> removes the static 0-Doppler lines
rangeFFT = rangeFFT - mean(rangeFFT, 4);
numRangeBins = size(rangeFFT, 2);
rangeAxis    = (0:numRangeBins-1) * rangeResolution;
% Doppler FFT
window2D = reshape(hamming(numChirpsVirtual)', [1 1 numChirpsVirtual 1]);
rangeFFT_windowed = rangeFFT .* window2D;
dopplerFFT = fftshift(fft(rangeFFT_windowed, numChirpsVirtual, 3), 3);
dopplerFFT = dopplerFFT / numChirpsVirtual;
PRT            = chirpDuration;
fd_max         = 1 / (2 * PRT);
maxDoppler     = fd_max * lambda;
numDopplerBins = size(dopplerFFT, 3);
numFrames      = size(dopplerFFT, 4);
dopplerAxis = linspace(-maxDoppler, maxDoppler, numDopplerBins);
timeAxis    = (0:numFrames-1) * chirpDuration;
% Doppler-Time Map
rangeEnd   = 100;
rangeStart = 1;
dopplerTimeMap = zeros(numDopplerBins, numFrames);
for frameIdx = 1:numFrames
    dopplerSlice = zeros(numDopplerBins, 1);
    for r = rangeStart:rangeEnd
        frameData    = squeeze(dopplerFFT(:, r, :, frameIdx));
        dopplerMag   = mean(abs(frameData), 1);
        dopplerSlice = dopplerSlice + dopplerMag.';
    end
    dopplerTimeMap(:, frameIdx) = dopplerSlice / (rangeEnd - rangeStart + 1);
end
% Peak-normalize (linear) + dB
dopplerTimeMap = dopplerTimeMap / max(dopplerTimeMap(:));
dopplerTimeMap_dB = 20 * log10(dopplerTimeMap + eps);
dopplerTimeMap_dB(dopplerTimeMap_dB < -20) = -20;   % floor clip
