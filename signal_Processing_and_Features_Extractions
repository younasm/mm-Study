    binPath  = fullfile(files(k).folder, files(k).name);
    [~, tag] = fileparts(files(k).name);     % FileName = bin name without extension
try
        [featRow, roiFeat, specFeat] = extract_roi_features( ...
            binPath, tag, P, activityLabel, conditionLabel, outDir);
% per-file .mat keeps the full feature curves (energy/centroid/bandwidth)
        save(fullfile(outDir, sprintf('FEAT_%s.mat', tag)), 'roiFeat', 'specFeat');
        masterTable = [masterTable; featRow]; %#ok<AGROW>
