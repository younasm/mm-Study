%% ====================== PER-FILE PROCESSING FUNCTION ======================
function [featRow, roiFeat, specFeat] = extract_roi_features(binPath, tag, P, activityLabel, conditionLabel, outDir)
% ---- load + reshape [Rx, ADC, Chirps, Frames] ----
    adcDataRaw = readDCA1000(binPath);
    adcDataRaw = reshape(adcDataRaw, P.numRx, P.numADCSamples, P.loops, P.frames);
% ---- TDM-MIMO virtual array formation (de-interleave the 2 Tx) ----
    adcDataVirtual = zeros(P.numVirtualRx, P.numADCSamples, P.numChirpsVirtual, P.frames);
    for txIdx = 1:P.numTx
        adcDataVirtual((txIdx-1)*P.numRx+1 : txIdx*P.numRx, :, :, :) = ...
            adcDataRaw(:, :, txIdx:P.numTx:end, :);
    end
% ---- range window + within-frame clutter removal + range FFT ----
    window1D       = hamming(P.numADCSamples)';
    adcDataVirtual = adcDataVirtual .* window1D;
    adcDataVirtual = adcDataVirtual - mean(adcDataVirtual, 3);   % within-frame clutter removal
    rangeFFT = fft(adcDataVirtual, P.numADCSamples, 2) / P.numADCSamples;
    rangeFFT = rangeFFT(:, 1:P.numADCSamples/2, :, :);           % keep positive-range half
% ---- cross-frame clutter removal -> removes static 0-Doppler lines ----
    rangeFFT = rangeFFT - mean(rangeFFT, 4);
% ---- doppler window + doppler FFT ----
    window2D = reshape(hamming(P.numChirpsVirtual)', [1 1 P.numChirpsVirtual 1]);
    rangeFFT_windowed = rangeFFT .* window2D;
    dopplerFFT = fftshift(fft(rangeFFT_windowed, P.numChirpsVirtual, 3), 3) / P.numChirpsVirtual;
% ---- axes ----
    fd_max         = 1 / (2 * P.chirpDuration);
    maxDoppler     = fd_max * P.lambda;
    numDopplerBins = size(dopplerFFT, 3);
    numFrames      = size(dopplerFFT, 4);
    velocityAxis   = linspace(-maxDoppler, maxDoppler, numDopplerBins).';   % [vel x 1]
    timeAxis       = (0:numFrames-1) * P.chirpDuration;
% ---- Doppler-time map (integrate over range bins) ----
    rEnd = min(P.rangeEnd, size(dopplerFFT,2));
    dopplerTimeMap = zeros(numDopplerBins, numFrames);
    for frameIdx = 1:numFrames
        dopplerSlice = zeros(numDopplerBins, 1);
        for r = P.rangeStart:rEnd
            frameData  = squeeze(dopplerFFT(:, r, :, frameIdx));
            dopplerMag = mean(abs(frameData), 1);
            dopplerSlice = dopplerSlice + dopplerMag.';
        end
        dopplerTimeMap(:, frameIdx) = dopplerSlice / (rEnd - P.rangeStart + 1);
    end
% ---- peak-normalize (linear) + dB ----
    avgDoppler    = dopplerTimeMap / max(dopplerTimeMap(:));     % [vel x time], linear
    avgDoppler_dB = 20*log10(avgDoppler + eps);
% ---- SNR proxy (peak is always 0 dB, so -median ≈ peak-to-noise gap) ----
    snrProxy = -median(avgDoppler_dB(:));
% ---- ROI mask (adaptive mean + 2*std, component filter) ----
    meanSpec  = mean(avgDoppler_dB(:));
    stdSpec   = std(avgDoppler_dB(:));
    threshold = meanSpec + 2*stdSpec;
    binaryMask = avgDoppler_dB > threshold;
    CC    = bwconncomp(binaryMask);
    stats = regionprops(CC, 'Area');
    filteredMask = false(size(binaryMask));
for i = 1:numel(stats)
if stats(i).Area > P.minArea
            filteredMask(CC.PixelIdxList{i}) = true;
end
end
if ~any(filteredMask(:))
        error('empty ROI (no pixels above threshold)');
end
    maskedSpectrogram = avgDoppler_dB .* filteredMask;
% ---- ROI morphology features (union of foreground as one region) ----
    rs = regionprops(double(filteredMask), 'Area','Centroid','Orientation', ...
'Perimeter','MajorAxisLength','MinorAxisLength','Eccentricity');
    roiFeat.Area            = rs.Area;
    roiFeat.Centroid        = rs.Centroid;
    roiFeat.Orientation     = rs.Orientation;
    roiFeat.Perimeter       = rs.Perimeter;
    roiFeat.MajorAxisLength = rs.MajorAxisLength;
    roiFeat.MinorAxisLength = rs.MinorAxisLength;
    roiFeat.Eccentricity    = rs.Eccentricity;
% ---- spectrogram features (full linear power) ----
    Pw = avgDoppler;  v = velocityAxis;
    energyCurve = sum(Pw, 1);
    W = Pw ./ (sum(Pw,1) + eps);
    centroidCurve  = sum(W .* v, 1);
    bandwidthCurve = sqrt(sum(W .* (v - centroidCurve).^2, 1));
    p = Pw(:); p = p / (sum(p) + eps);
    specEntropy = -sum(p .* log2(p + eps));
    Pv = sum(Pw,2); wv = Pv / (sum(Pv) + eps);
    muV  = sum(wv .* v);
    sigV = sqrt(sum(wv .* (v - muV).^2));
    specSkewness = sum(wv .* (v - muV).^3) / (sigV^3 + eps);
    specFeat.entropy        = specEntropy;
    specFeat.skewness       = specSkewness;
    specFeat.centroidCurve  = centroidCurve;
    specFeat.bandwidthCurve = bandwidthCurve;
    specFeat.energyCurve    = energyCurve;
    specFeat.centroidMean   = mean(centroidCurve);
    specFeat.bandwidthMean  = mean(bandwidthCurve);
    specFeat.energyTotal    = sum(energyCurve);
    specFeat.snrProxy       = snrProxy;
% ---- borderless gray ROI image (dataset input) ----
    gimg = (maskedSpectrogram - P.floor_dB) / (0 - P.floor_dB);
    gimg = flipud(min(max(gimg,0),1));
    imwrite(im2uint8(gimg), fullfile(outDir, sprintf('ROI_%s.png', tag)));
% ---- borderless RGB doppler-time spectrogram (jet, dataset input) ----
    rgbimg = (avgDoppler_dB - P.floor_dB_rgb) / (0 - P.floor_dB_rgb);
    rgbimg = flipud(min(max(rgbimg,0),1));
    rgbimg = ind2rgb(im2uint8(rgbimg), jet(256));
    imwrite(rgbimg, fullfile(outDir, sprintf('RGB_%s.png', tag)));
% ---- scalar feature row keyed by FileName ----
    featRow = table(string(tag), string(activityLabel), string(conditionLabel), ...
        roiFeat.Area, roiFeat.Orientation, roiFeat.Centroid(1), roiFeat.Centroid(2), ...
        roiFeat.Perimeter, roiFeat.MajorAxisLength, roiFeat.MinorAxisLength, roiFeat.Eccentricity, ...
        specFeat.entropy, specFeat.skewness, specFeat.centroidMean, specFeat.bandwidthMean, specFeat.energyTotal, ...
        snrProxy, ...
'VariableNames', {'FileName','Activity','Condition', ...
'Area','Orientation','CentroidX','CentroidY','Perimeter', ...
'MajorAxis','MinorAxis','Eccentricity', ...
'Entropy','Skewness','CentroidMean','BandwidthMean','EnergyTotal', ...
'SNRproxy'});
end

