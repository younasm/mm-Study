% Adaptive thresholding
meanSpec  = mean(avgDopplerMagnitude_dB(:));
stdSpec   = std(avgDopplerMagnitude_dB(:));
threshold = meanSpec + 2 * stdSpec;

% Binarization
binaryMask = avgDopplerMagnitude_dB > threshold;

% Connected component analysis
CC    = bwconncomp(binaryMask);
