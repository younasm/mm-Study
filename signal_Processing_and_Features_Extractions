[interpTimeGrid, interpVelocityGrid] = meshgrid(interpTimeAxis, interpVelocityAxis);

avgDopplerMagnitude_dB_Interp = interp2(timeGrid, velocityGrid, avgDopplerMagnitude_dB, ...
