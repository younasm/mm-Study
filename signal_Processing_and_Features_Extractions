idleTime      = 100e-6;                 % from chirp config
rampEndTime   = 57e-6;                  % corrected (was 60e-6)
T_c           = idleTime + rampEndTime; % chirp cycle time / PRI = 157 us
PRF           = 1 / T_c;
T_framePeriod = 50e-3;                  % frame repetition period (was mislabeled T_chirp)

% Clutter removal (subtract mean over slow-time / chirps)
adcData = adcData - mean(adcData, 3);

% Range window + Range FFT
windowRange = hamming(numADCSamples)';
adcData     = adcData .* windowRange;
rangeFFT    = fft(adcData, numADCSamples, 2) / numADCSamples;

% Doppler window + Doppler FFT
windowDoppler = reshape(hamming(loops)', [1, 1, loops, 1]);
rangeFFT      = rangeFFT .* windowDoppler;
dopplerFFT    = fftshift(fft(rangeFFT, loops, 3), 3);
dopplerMagnitude = abs(dopplerFFT);

% Collapse Rx + range -> Doppler-time
% (sum keeps target energy better than mean-over-all-bins; switch if preferred)
avgDopplerMagnitude = squeeze(sum(sum(dopplerMagnitude, 1), 2));   % [loops x frames]

avgDopplerMagnitude = avgDopplerMagnitude / max(avgDopplerMagnitude(:));   % 0 dB = peak

% --- Axes (FIX 1: Doppler axis from PRF, not ADC rate) ---
dopplerFreqAxis = (-loops/2 : loops/2-1) * (PRF / loops);
velocityAxis    = dopplerFreqAxis * lambda / 2;          % v_max = lambda/(4*T_c)
timeAxis        = (0:frames-1) * T_framePeriod;

% Convert to dB (computed once)
